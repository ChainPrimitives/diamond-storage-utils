{
  "name": "diamond-storage-utils",
  "version": "1.0.0",
  "description": "Safe Diamond storage layout helpers with collision detection for EIP-2535",
  "license": "MIT",
  "author": "Subaskar Sivakumar <subaskar.sr@gmail.com> (https://github.com/Subaskar-S)",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChainPrimitives/diamond-storage-utils.git"
  },
  "keywords": [
    "diamond",
    "eip-2535",
    "storage",
    "proxy",
    "solidity",
    "facets",
    "upgrade",
    "ethereum",
    "blockchain",
    "collision-detection"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist coverage",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "peerDependencies": {
    "ethers": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^1.3.0",
    "ethers": "^6.11.0",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.3.0"
  }
}
